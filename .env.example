# Stripe — get keys at https://dashboard.stripe.com/acct_1TmfDMRWcwLj7QiT/apikeys
# Use sk_test_/pk_test_ while developing; switch to sk_live_/pk_live_ in production.
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret — from `stripe listen` locally, or the dashboard
# webhook endpoint in production.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Telegram sale notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public site URL (used for metadata, sitemap, canonicals)
NEXT_PUBLIC_SITE_URL=https://example.com

# Analytics (optional — scripts only load when set)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
